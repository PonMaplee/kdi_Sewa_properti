# ========================================
# Digital Lease Backend Configuration
# ========================================

# Server
PORT=4000

# Blockchain / RPC (Sepolia Testnet)
RPC_URL=https://rpc.sepolia.org
CONTRACT_ADDRESS=0x_YOUR_DEPLOYED_CONTRACT_ADDRESS_HERE

# MQTT Broker (untuk IoT Smart Lock)
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_TOPIC_PREFIX=digital-lease/door

# Opsional: Private key untuk transaksi otomatis (JANGAN expose di production!)
# PRIVATE_KEY=0x...
